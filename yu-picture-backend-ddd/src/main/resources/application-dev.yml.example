# 开发环境配置
# 注意：此文件包含敏感信息，已在 .gitignore 中排除，请勿提交到 Git
# 请复制此文件为 application-dev.yml 并填写真实的配置信息

# 腾讯云COS对象存储配置
cos:
  client:
    # COS 访问域名（格式：https://{bucket}.cos.{region}.myqcloud.com）
    host: https://your-bucket.cos.your-region.myqcloud.com
    # 腾讯云账号的 SecretId（以AKID开头的字符串）
    secretId: YOUR_SECRET_ID
    # 腾讯云账号的 SecretKey（请在腾讯云控制台查找真实的SecretKey）
    secretKey: YOUR_SECRET_KEY
    # COS 所在地域
    region: ap-guangzhou
    # COS 存储桶名称（格式：bucketname-appid）
    bucket: your-bucket-name

## 腾讯云COS配置 配置在dev的配置文件中，不能上传到git仓库

# 阿里云 AI 配置
aliYunAi:
  # 阿里云百炼 API Key，请到控制台获取：https://bailian.console.aliyun.com/
  apiKey: YOUR_API_KEY

